{
  "snapshot_name": "TD3 public source-and-evidence snapshot",
  "repository": "https://github.com/magictierwheel/TD3",
  "branch": "main",
  "snapshot_root": ".",
  "purpose": "Keep the reviewable GitHub tree aligned with the local project layout without publishing large or disposable training artifacts.",
  "tracked_top_level_directories": [
    ".github",
    ".research",
    "docs",
    "experiments",
    "gym_pybullet_drones",
    "reproducibility",
    "tests",
    "tools"
  ],
  "tracked_project_files": [
    "AGENTS.md",
    "CITATION.cff",
    "LICENSE",
    "PROJECT_HANDOFF.md",
    "PROJECT_STRUCTURE.md",
    "README.md",
    "RL_PAPER_EXECUTION_PLAN.md",
    "pyproject.toml",
    ".gitignore"
  ],
  "reviewable_results_root": "experiments/circular_tracking/results/hidden_disturbance_td3_paper",
  "reviewable_result_content": [
    "README.md files describing each protocol/stage and its local-only artifacts",
    "small JSON/CSV manifests, summaries, gate decisions, and run metadata",
    "configuration and reproducibility evidence needed to audit the experiment"
  ],
  "local_only_generated_directories": [
    ".git",
    ".pytest_cache",

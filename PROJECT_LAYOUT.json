    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/logs",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/tensorboard",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/cache",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/videos",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/trajectories"
  ],
  "excluded_large_or_disposable_patterns": [
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/*.pkl",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/*.npz",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/*.pt",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/*.pth",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/*.zip",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/replay_buffer*",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/trajectory.csv",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/control.csv",
    "experiments/circular_tracking/results/hidden_disturbance_td3_paper/**/progress.csv",

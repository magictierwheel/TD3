{
  "protocol_version": "1.0.0",
  "status": "frozen_pre_stage_a",
  "frozen_date": "2026-07-10",
  "research_question": "Under identical observable flight-state information and hidden time-varying disturbances, does a PID residual prior improve TD3 safety, sample efficiency, and circular-tracking robustness?",
  "controllers": [
    "pid",
    "direct_td3",
    "residual_td3"
  ],
  "seed_sets": {
    "unit_test": {"start": 9000, "end": 9099, "inclusive": true},
    "training": {"start": 0, "end": 4, "inclusive": true},
    "validation": {"start": 100, "end": 109, "inclusive": true},
    "test": {"start": 200, "end": 219, "inclusive": true},
    "unseen": {"start": 300, "end": 319, "inclusive": true}
  },
  "trajectory": {
    "radius_m": 0.3,
    "period_sec": 10.0,
    "height_m": 1.0,
    "training_duration_sec": 20.0,
    "evaluation_duration_sec": 30.0,
    "fixed_initial_phase": true
  },
  "observation": {
    "main_history_steps": 8,
    "single_frame_ablation_steps": 1,
    "sensor_noise_model": "none",
    "privileged_fields_forbidden": [
      "wind",
      "density",
      "thermal",
      "thrust_efficiency",
      "torque_efficiency",
      "scenario_label",
      "disturbance_seed"
    ]
  },
  "action": {
    "dimension": 4,
    "direct_rpm_span": "MAX_RPM - HOVER_RPM",
    "residual_rpm_limit": "0.10 * MAX_RPM",
    "residual_zero_output_initialization": true,
    "motor_bounds": [0.0, "MAX_RPM"]
  },
  "gate": {
    "inputs": [
      "position_error",
      "pid_motor_headroom"
    ],
    "error_gate_start_m": 0.03,
    "error_gate_full_m": 0.2,
    "headroom_full_fraction": 0.1,
    "no_gate_ablation": true
  },
  "disturbance": {
    "training_profiles": [
      "standard",
      "random_wind",
      "actuator_loss",
      "compound"
    ],
    "training_profile_probabilities": [0.25, 0.25, 0.25, 0.25],
    "train_wind_limit_mps": 1.5,
    "train_efficiency_range": [0.9, 1.0],
    "train_knot_interval_sec": [1.0, 3.0],
    "unseen_wind_limit_mps": 2.5,
    "unseen_efficiency_range": [0.8, 0.9],
    "unseen_knot_interval_sec": [0.5, 1.5],
    "process_horizon": "rollout_duration",
    "unseen_geometry_scope": "nominal_only"
  },
  "reward": {
    "formula": "-(2.0*position_error_norm + 0.5*velocity_error_norm + 1.0*altitude_error_norm + 0.2*tilt_norm + 0.05*applied_motor_energy + 0.05*applied_motor_smoothness + 2.0*saturation_fraction) - (50.0 if current_failure_reason else 0.0)",
    "normalization": {
      "position_error_norm": "norm(reference_position - measured_position) / 2.0",
      "velocity_error_norm": "norm(reference_velocity - measured_velocity) / 3.0",
      "altitude_error_norm": "abs(measured_z - reference_z) / 2.0",
      "tilt_norm": "norm([roll, pitch]) / pi",
      "applied_motor_energy": "mean((applied_rpm / MAX_RPM) ** 2)",
      "applied_motor_smoothness": "mean(abs(applied_rpm - previous_applied_rpm)) / MAX_RPM",
      "saturation_fraction": "mean((applied_rpm <= 0) or (applied_rpm >= MAX_RPM))"
    },
    "terminal_semantics": "The failure reason is computed from the current state by one pure helper. Reward and termination call the same helper, so the penalty is applied on the terminal transition itself.",
    "position": 2.0,
    "velocity": 0.5,
    "altitude": 1.0,
    "tilt": 0.2,
    "applied_motor_energy": 0.05,
    "applied_motor_smoothness": 0.05,
    "saturation": 2.0,
    "terminal_failure_penalty": 50.0,
    "shared_by_td3_modes": true
  },
  "td3": {
    "network_architecture": [256, 256],
    "learning_rate": 0.001,
    "batch_size": 256,
    "buffer_size": 1000000,
    "learning_starts": 2000,
    "gamma": 0.99,
    "tau": 0.005,
    "train_freq": 1,
    "gradient_steps": 1,
    "policy_delay": 2,
    "target_policy_noise": 0.2,
    "target_noise_clip": 0.5,
    "action_noise_sigma": 0.1
  },
  "budgets": {
    "stage_a": 20000,
    "stage_b": 50000,
    "stage_c_max": 100000,
    "checkpoints": [5000, 10000, 20000, 50000, 100000]
  },
  "stage_gates": {
    "stage_a": {
      "scenario": "compound",
      "standard_gate": "residual standard failure_count == 0 AND residual standard steady_position_rmse_success_only <= 1.10 * pid standard steady_position_rmse_success_only",
      "comparison_objects": ["pid", "direct_td3"],
      "comparison_logic": "standard_gate AND (compound_improvement_vs_pid OR compound_improvement_vs_direct_td3)",
      "compound_improvement": "residual failure_count <= comparator failure_count - 1 OR (failure_count equal AND residual failure_penalized_horizon_error <= 0.95 * comparator failure_penalized_horizon_error)"
    },
    "stage_b": {
      "scenario": "compound",
      "per_training_seed_direction": "standard_gate AND compound_improvement_vs_pid AND compound_improvement_vs_direct_td3",
      "required_seed_count": 2,
      "total_seed_count": 3
    },
    "stage_c": {
      "scenario": "compound",
      "per_training_seed_direction": "standard_gate AND compound_improvement_vs_pid AND compound_improvement_vs_direct_td3",
      "positive_claim_seed_count": 4,
      "total_seed_count": 5,
      "confidence_interval_requirement": "clustered_or_hierarchical_95_percent_ci"
    },
    "standard_failure_count": 0,
    "standard_rmse_ratio_to_pid_max": 1.1,
    "stage_a_validation_seeds": 10,
    "stage_a_min_failure_count_reduction": 1,
    "stage_a_min_failure_penalized_error_improvement_fraction": 0.05,
    "stage_b_required_training_seeds": 2,
    "stage_b_total_training_seeds": 3,
    "stage_c_positive_direction_seeds": 4,
    "stage_c_total_training_seeds": 5,
    "global_checkpoint_order": [
      "failure_rate",
      "failure_penalized_horizon_error",
      "steady_position_rmse_success_only",
      "smaller_budget"
    ]
  },
  "ablation": {
    "run_only_after_stage_b_go": true,
    "training_seeds": [0, 1, 2],
    "budget": 50000,
    "scenarios": [
      "standard",
      "compound"
    ],
    "variants": [
      "residual_td3_no_gate",
      "residual_td3_single_frame",
      "zero_initial_residual",
      "sample_budget_checkpoints"
    ]
  },
  "runtime": {
    "python": "3.11",
    "torch_device": "cpu",
    "max_training_processes": 4,
    "max_evaluation_workers": 6,
    "threads_per_process": 1
  },
  "reporting": {
    "failure_first": true,
    "hierarchical_confidence_interval": true,
    "geometry_generalization_claim": "unsupported",
    "legacy_results_allowed_as_main_evidence": false
  }
}

FROM python:3.10-slim

ENV MPLBACKEND=Agg \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /workspace

COPY pyproject.toml README.md LICENSE CITATION.cff ./
COPY gym_pybullet_drones ./gym_pybullet_drones
COPY tests ./tests

RUN python -m pip install --upgrade pip \
    && python -m pip install -e .

COPY experiments/hover_rl_reproduction/scripts/reproduce_hover_short.py ./experiments/hover_rl_reproduction/scripts/reproduce_hover_short.py

CMD ["python", "experiments/hover_rl_reproduction/scripts/reproduce_hover_short.py", "--timesteps", "2048", "--output-folder", "experiments/hover_rl_reproduction/results/repro_hover_short"]
